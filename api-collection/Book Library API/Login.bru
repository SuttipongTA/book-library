meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/login
  body: json
  auth: inherit
}

body:json {
  {
    "username": "admin",
    "password": "admin1234"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
      const data = res.getBody();
      bru.setEnvVar("token", data.token);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
